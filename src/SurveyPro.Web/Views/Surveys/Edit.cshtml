@model SurveyPro.Web.ViewModels.Surveys.EditSurveyViewModel

@{
    ViewData["Title"] = "Edit Survey";
}

@section Styles {
    <link rel="stylesheet" href="~/css/surveys/edit.css" asp-append-version="true" />
}

<h1>Edit Survey</h1>

@if (!string.IsNullOrWhiteSpace(Model.AccessCode))
{
    <div class="alert alert-info d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <strong>Invite code:</strong> <code>@Model.AccessCode</code>
            <div class="small text-muted mt-1">
                Share this code or link with respondents so they can open the survey directly.
            </div>
        </div>

        <a asp-controller="Participation" asp-action="Join" asp-route-code="@Model.AccessCode"
           class="btn btn-outline-primary btn-sm">
            Open respondent link
        </a>

        <a asp-controller="Surveys" asp-action="Responses" asp-route-id="@Model.Id"
           class="btn btn-outline-info btn-sm">
            View responses
        </a>
    </div>
}

<form asp-action="Edit" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsPublic" class="form-check-input" />
        <label asp-for="IsPublic" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="My" class="btn btn-secondary">Cancel</a>
</form>

<hr />

@if (TempData["SuccessMessage"] is string success)
{
    <div class="alert alert-success">@success</div>
}

@if (TempData["ErrorMessage"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="d-flex justify-content-between align-items-center">
    <h3>Questions</h3>
    <button type="button" class="btn btn-success js-toggle-question-form">+ Add Question</button>
</div>

@if (Model.Questions != null && Model.Questions.Any())
{
    <div class="mt-3">
       @foreach (var q in Model.Questions.OrderBy(q => q.OrderNumber))
        {
            <div class="card mb-2">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5>@q.OrderNumber. @q.Text</h5>
                            <small class="text-muted">Type: @q.Type</small>

                            @if (q.Options != null && q.Options.Any())
                            {
                                <ul class="mt-2">
                                    @foreach (var opt in q.Options)
                                    {
                                        <li>@opt</li>
                                    }
                                </ul>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            <button type="button"
                                    class="btn btn-warning btn-sm js-toggle-edit-form"
                                    data-question-id="@q.Id">✏️</button>

                            <form asp-controller="Questions" asp-action="Delete" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@q.Id" />
                                <input type="hidden" name="surveyId" value="@Model.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">🗑</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div id="editForm-@q.Id" class="mb-3 border p-3 rounded survey-edit-hidden">
                <form asp-controller="Questions" asp-action="Edit" method="post"
                      class="js-edit-question-form"
                      data-question-id="@q.Id">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="Id" value="@q.Id" />
                    <input type="hidden" name="SurveyId" value="@Model.Id" />

                    <div class="mb-2">
                        <input name="Text" class="form-control" placeholder="Enter your question..."
                            value="@q.Text" />
                    </div>

                    <div class="mb-2">
                        <select name="Type" id="editType-@q.Id" class="form-select js-edit-type"
                            data-question-id="@q.Id">
                            <option value="Text" selected="@(q.Type == "Text")">Text</option>
                            <option value="SingleChoice" selected="@(q.Type == "SingleChoice")">Single Choice</option>
                            <option value="MultipleChoice" selected="@(q.Type == "MultipleChoice")">Multiple Choice</option>
                            <option value="Likert" selected="@(q.Type == "Likert")">Likert Scale</option>
                        </select>
                    </div>

                    <div id="editOptionsBlock-@q.Id" class="@(q.Type == "Text" ? "survey-edit-hidden" : string.Empty)">
                        <div id="editOptionsContainer-@q.Id" class="mb-2">
                            @if (q.Options != null)
                            {
                                @for (int i = 0; i < q.Options.Count; i++)
                                {
                                    <div class="d-flex mt-1 edit-option-row-@q.Id">
                                        <input name="Options[@i]" class="form-control"
                                            placeholder="Option" value="@q.Options[i]" />
                                        <button type="button"
                                            class="btn btn-danger ms-2 js-remove-edit-option"
                                            data-question-id="@q.Id">X</button>
                                    </div>
                                }
                            }
                        </div>
                        <button type="button"
                            class="btn btn-secondary btn-sm js-add-edit-option"
                            data-question-id="@q.Id">+ Add Option</button>
                    </div>

                    <div class="mt-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <button type="button"
                            class="btn btn-secondary js-toggle-edit-form"
                            data-question-id="@q.Id">Cancel</button>
                    </div>
                </form>
            </div>
        }
    </div>
}
else
{
    <p class="mt-3">No questions yet</p>
}

<div id="questionForm" class="mt-3 border p-3 rounded survey-edit-hidden">

    <form asp-controller="Questions" asp-action="Create" method="post"
          class="js-create-question-form">
        <input type="hidden" name="SurveyId" value="@Model.Id" />

        <div class="mb-2">
            <input name="Text" class="form-control" placeholder="Enter your question..." />
        </div>

        <div class="mb-2">
            <select name="Type" id="questionType" class="form-select js-question-type">
                <option value="Text">Text</option>
                <option value="SingleChoice">Single Choice</option>
                <option value="MultipleChoice">Multiple Choice</option>
                <option value="Likert">Likert Scale</option>
            </select>
        </div>

        <div id="optionsBlock" class="survey-edit-hidden">
            <div id="optionsContainer" class="mb-2"></div>

            <button type="button" class="btn btn-secondary btn-sm js-add-option">
                + Add Option
            </button>
        </div>

        <div class="mt-2">
            <button type="submit" class="btn btn-primary">Save Question</button>
        </div>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/surveys/edit.js" asp-append-version="true"></script>
}