@model SurveyPro.Web.ViewModels.Participation.SurveyParticipationViewModel

@{
    ViewData["Title"] = "Join Survey";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">@Model.Title</h1>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="text-muted mb-0">@Model.Description</p>
        }
    </div>

    <span class="badge bg-secondary">
        Code: @Model.AccessCode
    </span>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">
        @successMessage
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <div class="alert alert-info">
        Sign in as a respondent to save a draft while filling this survey.
    </div>
}

@if (Model.IsSubmitted)
{
    <div class="alert alert-success mt-3">
        <strong>You have already submitted this survey.</strong>
        Your answers cannot be changed.
    </div>

    @for (var i = 0; i < Model.Questions.Count; i++)
    {
        var question = Model.Questions[i];

        <div class="survey-question-card card mb-3">
            <div class="card-body">
                <h5 class="card-title">
                    @question.OrderNumber. @question.Text
                </h5>

                @if (question.Type == "Text")
                {
                    <p class="form-control-plaintext">
                        @(question.TextAnswer ?? "—")
                    </p>
                }
                else if (question.Type == "MultipleChoice")
                {
                    @foreach (var option in question.Options)
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   disabled
                                   @(question.SelectedOptionIds.Contains(option.Id)
                                       ? "checked"
                                       : "") />

                            <label class="form-check-label">
                                @option.Text
                            </label>
                        </div>
                    }
                }
                else
                {
                    @foreach (var option in question.Options)
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="radio"
                                   disabled
                                   @(question.SelectedOptionId == option.Id
                                       ? "checked"
                                       : "") />

                            <label class="form-check-label">
                                @option.Text
                            </label>
                        </div>
                    }
                }
            </div>
        </div>
    }
}
else
{
    <form asp-action="Clear"
          method="post"
          class="mb-3">

        @Html.AntiForgeryToken()

        <input type="hidden"
               name="code"
               value="@Model.AccessCode" />

        <button type="submit"
                class="btn btn-outline-danger btn-sm">
            Clear all answers
        </button>
    </form>

    <form asp-action="Join"
          method="post"
          id="survey-form">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="SurveyId" />
        <input type="hidden" asp-for="AccessCode" />

        @for (var i = 0; i < Model.Questions.Count; i++)
        {
            var question = Model.Questions[i];

            <div class="survey-question-card card mb-3">
                <div class="card-body">

                    <h5 class="card-title">
                        @question.OrderNumber. @question.Text
                    </h5>

                    @if (question.Type == "Text")
                    {
                        <textarea asp-for="Questions[i].TextAnswer"
                                  class="form-control"
                                  rows="4"></textarea>

                        <button type="button"
                            class="btn btn-sm btn-outline-danger mt-2 js-clear-answer"
                                data-clear-type="text"
                            data-question-index="@i">
                            Clear
                        </button>
                    }
                    else if (question.Type == "MultipleChoice")
                    {
                        <div class="d-grid gap-2">

                            @for (var optionIndex = 0;
                                  optionIndex < question.Options.Count;
                                  optionIndex++)
                            {
                                var option = question.Options[optionIndex];

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="Questions[@i].SelectedOptionIds"
                                           value="@option.Id"
                                           @(question.SelectedOptionIds.Contains(option.Id)
                                               ? "checked"
                                               : "") />

                                    <label class="form-check-label">
                                        @option.Text
                                    </label>
                                </div>
                            }
                        </div>

                        <button type="button"
                            class="btn btn-sm btn-outline-danger mt-2 js-clear-answer"
                                data-clear-type="checkbox"
                            data-question-index="@i">
                            Clear
                        </button>
                    }
                    else
                    {
                        <div class="d-grid gap-2">

                            @for (var optionIndex = 0;
                                  optionIndex < question.Options.Count;
                                  optionIndex++)
                            {
                                var option = question.Options[optionIndex];

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="Questions[@i].SelectedOptionId"
                                           value="@option.Id"
                                           @(question.SelectedOptionId == option.Id
                                               ? "checked"
                                               : "") />

                                    <label class="form-check-label">
                                        @option.Text
                                    </label>
                                </div>
                            }
                        </div>

                        <button type="button"
                            class="btn btn-sm btn-outline-danger mt-2 js-clear-answer"
                                data-clear-type="radio"
                            data-question-index="@i">
                            Clear
                        </button>
                    }

                    <input type="hidden"
                           asp-for="Questions[i].QuestionId" />

                    <input type="hidden"
                           asp-for="Questions[i].Type" />

                    <input type="hidden"
                           asp-for="Questions[i].Text" />

                    <input type="hidden"
                           asp-for="Questions[i].OrderNumber" />
                </div>
            </div>
        }

        <div class="d-flex gap-2 mb-2">
            <button type="submit"
                    class="btn btn-primary">
                Save draft
            </button>

            <a asp-controller="Surveys"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Back to surveys
            </a>
        </div>
    </form>

    <form asp-action="Submit"
          asp-controller="Participation"
          method="post">

        @Html.AntiForgeryToken()

        <input type="hidden"
               name="accessCode"
               value="@Model.AccessCode" />

        <input type="hidden"
               name="surveyId"
               value="@Model.SurveyId" />

        <button type="submit"
                class="btn btn-success">
            Submit answers
        </button>
    </form>
}

@section Scripts {
    <script src="~/js/survey-participation.js"
            asp-append-version="true"></script>
}