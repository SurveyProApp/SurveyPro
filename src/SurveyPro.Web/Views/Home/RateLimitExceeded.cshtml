@{
    ViewData["Title"] = "Too Many Requests";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-lg">
            <div class="card-body p-5">
                <div class="text-uppercase text-muted small mb-2">Request throttled</div>
                <h1 class="display-6 fw-bold mb-3">Too many requests from your IP</h1>
                <p class="lead text-muted mb-4">
                    You reached the allowed request rate. Please wait a short time and try again.
                </p>
                <a asp-action="Index" class="btn btn-primary">Back to home</a>
            </div>
        </div>
    </div>
</div>
